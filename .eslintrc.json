{
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/eslint-recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:import/recommended",
    "plugin:import/electron",
    "plugin:import/typescript",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "rules": {
    "@typescript-eslint/no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["**/cylinderscan/**"],
            "message": "Shared code must not import from cylinderscan/. Only main.ts (the orchestrator) may import mode-specific modules."
          },
          {
            "group": ["**/graviscan/**"],
            "message": "Shared code must not import from graviscan/. Only main.ts (the orchestrator) may import mode-specific modules."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/main/cylinderscan/**",
        "src/main/graviscan/**",
        "src/main/main.ts",
        "src/renderer/graviscan/**",
        "src/components/graviscan/**",
        "src/renderer/App.tsx",
        "tests/**"
      ],
      "rules": {
        "@typescript-eslint/no-restricted-imports": "off"
      }
    }
  ]
}
