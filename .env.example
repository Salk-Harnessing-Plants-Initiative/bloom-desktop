# Bloom Desktop Environment Configuration
#
# Copy this file to .env and configure for your local development environment.
# The .env file is gitignored and should NOT be committed.

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
#
# The database location is determined automatically based on environment:
#
# - Development (NODE_ENV=development): ~/.bloom/dev.db
# - Production (packaged app): ~/.bloom/data/bloom.db
# - E2E Tests: Configured via .env.e2e (tests/e2e/test.db)
# - Integration Tests: Custom paths passed directly to initializeDatabase()
#
# IMPORTANT: Do NOT set BLOOM_DATABASE_URL in your .env file for normal
# development. Bloom will automatically select and use the default database
# file at ~/.bloom/dev.db; Prisma CLI commands are required to manage the
# database schema (migrations, initialization, etc.).
#
# BLOOM_DATABASE_URL should ONLY be set for:
# - E2E tests (via .env.e2e)
# - Special debugging scenarios
#
# If you set BLOOM_DATABASE_URL, it OVERRIDES the automatic path selection.
# This can cause confusion when the app uses a different database than expected.
#
# For Prisma CLI commands (studio, migrate, etc.), the datasource is configured
# in prisma/schema.prisma to use file:./prisma/dev.db by default.

# =============================================================================
# NPM CONFIGURATION
# =============================================================================

# NPM Token for accessing @salk-hpi packages from GitLab
# Required for installing @salk-hpi/bloom-js and related packages
# Contact the team lead to obtain this token
# After setting this, copy .npmrc.example to .npmrc
NPM_TOKEN=your-gitlab-npm-token-here

# =============================================================================
# BLOOM API CREDENTIALS (optional)
# =============================================================================

# Used for manual testing of Bloom API integration
# These credentials are used by the Machine Configuration page to test
# connectivity and fetch scanner lists from the Bloom API.

BLOOM_TEST_USERNAME=your-test-username@salk.edu
BLOOM_TEST_PASSWORD=your-test-password
BLOOM_ANON_KEY=your-anon-key-here
BLOOM_API_URL=https://api.bloom.salk.edu/proxy

# =============================================================================
# GRAVISCAN V600 WEDGE FOLLOW-UPS (#228 + #236)
# =============================================================================
#
# These are deployed via ~/.bloom/.env on the production rig, NOT via
# this file. The example values below are placeholders — DO NOT commit
# real values. See README.md "Environment variables" section.
#
# Production rig location:
#   /home/graviscan/.bloom/.env
#
# Both are optional. Leaving them unset is the safe production default.

# Slack incoming webhook URL for V600 wedge notifications (#236).
# When set, the main process POSTs a structured message to this URL
# whenever the WedgeDetector recognizes one of three wedge signatures
# (sane_start_invalid, device_io_120s_zero_bytes, consecutive_failures).
# Rate-limited to 1 message per (scanner, session) per minute.
# Leave unset OR set to empty string to disable the notifier entirely.
# SECRET — NEVER commit a real value to git.
BLOOM_GRAVISCAN_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME

# libusb endpoint-recovery wrapper toggle (#228).
# When the LD_PRELOAD shim is loaded (Linux + real scanner mode), this
# variable controls whether the wrapper calls libusb_clear_halt() on
# bulk-IN TIMEOUT/PIPE errors. Default ON. Only case-insensitive
# "false" disables it.
# LIBUSB_ENDPOINT_RECOVERY=true
